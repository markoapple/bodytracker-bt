  "known_approximations": [
    {
      "name": "isotropic_focal_heuristic",
      "scope": "epipolar geometry pixel-space fallback",
      "risk": "low",
      "not_a_bug_because": "This is explicitly named as a heuristic and only used when the rigorous anisotropic path is unavailable. The anisotropic path is preferred when both cameras have valid distortion models."
    },
    {
      "name": "cauchy_scoring_for_identity",
      "scope": "identity arbitration Mahalanobis-to-score conversion",
      "risk": "low",
      "not_a_bug_because": "The Cauchy-style scoring is a policy choice for converting Mahalanobis distance to a 0-1 score. The hard Mahalanobis gate ensures decisions are not made on score alone."
    },
    {
      "name": "diagonal_covariance_approximation",
      "scope": "identity NLL computation",
      "risk": "medium",
      "not_a_bug_because": "Full covariance computation is deferred. The diagonal approximation with anisotropic lateral/depth variance captures the dominant directional uncertainty without cross-term complexity. Tests verify that lateral vs depth displacements produce different Mahalanobis values."
    },
    {
      "name": "single_entry_cache",
      "scope": "geometry cache implementation",
      "risk": "low",
      "not_a_bug_because": "The cache stores only the most recent geometry computation. This is sufficient because the calibration and config are stable during a solve frame. Multi-entry caching is deferred until profiling shows it's needed."
    }
  ]
